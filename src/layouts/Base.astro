---
interface Props {
  title: string;
  description?: string;
  hideSiteName?: boolean;
}

const {
  title,
  description = 'Personal website of Varun Gandhi',
  hideSiteName = false,
} = Astro.props;

const path = Astro.url.pathname;
const current = (prefix: string) => (path.startsWith(prefix) ? 'page' : undefined);
---

<!doctype html>
<html lang="en">
  <!--
    Hello, source reader. You found the easter egg.

    This website would not look the way it looks if not for Claude Code —
    it was built almost entirely in conversation with it.

    The design is inspired by the websites of Andrej Karpathy and Lilian Weng.

    More at /humans.txt
  -->
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      // Runs before paint to avoid a flash of the wrong theme.
      console.log('Built in conversation with Claude Code. Design inspired by Andrej Karpathy & Lilian Weng. See /humans.txt');
      const stored = localStorage.getItem('theme');
      const theme =
        stored ?? (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.dataset.theme = theme;
    </script>
  </head>
  <body>
    <header class="site-header">
      <nav>
        {hideSiteName ? <span /> : <a href="/" class="site-name">Varun Gandhi</a>}
        <div class="nav-links">
          <a href="/blog/" aria-current={current('/blog')}>Blog</a>
          <a href="/notes/" aria-current={current('/notes')}>Notes</a>
          <button id="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
            <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4m11.4-11.4 1.4-1.4"/></svg>
            <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"/></svg>
          </button>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>© {new Date().getFullYear()} Varun Gandhi</p>
    </footer>

    <script is:inline>
      document.getElementById('theme-toggle').addEventListener('click', () => {
        const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = next;
        localStorage.setItem('theme', next);
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #ffffff;
    --text: #333333;
    --heading: #111111;
    --text-muted: #6b6b6b;
    --link: #0f62ac;
    --border: #e4e4e4;
    --surface: #f6f6f6;
    --mark-bg: #fff1a8;
    color-scheme: light;
  }

  :root[data-theme='dark'] {
    --bg: #191c21;
    --text: #c4cad3;
    --heading: #eef0f3;
    --text-muted: #868e99;
    --link: #82b8ec;
    --border: #31353c;
    --surface: #21252b;
    --mark-bg: #5c4d12;
    color-scheme: dark;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0 auto;
    max-width: 58rem;
    padding: 0 1.5rem;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial,
      sans-serif;
    font-size: 1rem;
    line-height: 1.65;
    background: var(--bg);
    color: var(--text);
  }

  h1, h2, h3, h4 {
    line-height: 1.25;
    margin: 2rem 0 0.75rem;
    color: var(--heading);
  }

  h1 { font-size: 1.6rem; }
  h2 { font-size: 1.3rem; }
  h3 { font-size: 1.1rem; }

  a {
    color: var(--link);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.9em;
    background: var(--surface);
    padding: 0.15em 0.35em;
    border-radius: 4px;
  }

  pre {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1rem;
    overflow-x: auto;
  }

  pre code {
    background: none;
    padding: 0;
  }

  blockquote {
    margin: 1rem 0;
    padding-left: 1rem;
    border-left: 3px solid var(--border);
    color: var(--text-muted);
  }

  [id] {
    scroll-margin-top: 1.5rem;
  }

  hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }

  img {
    max-width: 100%;
  }

  figure {
    margin: 1.5rem 0;
  }

  figcaption {
    margin-top: 0.35rem;
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  /* GFM footnotes: visually secondary to the article body */
  .footnotes {
    margin-top: 3rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  table {
    border-collapse: collapse;
    display: block;
    overflow-x: auto;
  }

  th, td {
    border: 1px solid var(--border);
    padding: 0.4rem 0.7rem;
  }

  /* Header */
  .site-header nav {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 1.5rem 0 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .site-name {
    font-weight: 650;
    color: var(--heading);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.1rem;
  }

  .nav-links a {
    color: var(--text-muted);
  }

  .nav-links a:hover {
    color: var(--text);
    text-decoration: none;
  }

  .nav-links a[aria-current='page'] {
    color: var(--heading);
    font-weight: 600;
  }

  #theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-muted);
    padding: 0.2rem;
    display: inline-flex;
    align-items: center;
  }

  #theme-toggle:hover {
    color: var(--text);
  }

  :root[data-theme='dark'] .icon-moon { display: none; }
  :root[data-theme='light'] .icon-sun { display: none; }

  main {
    min-height: 70vh;
    padding-bottom: 3rem;
  }

  .site-footer {
    border-top: 1px solid var(--border);
    padding: 0.75rem 0 1.5rem;
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  /* highlight when arriving via a search deep link (text fragment) */
  ::target-text {
    background: var(--mark-bg);
    color: inherit;
  }

  /* KaTeX display math can overflow on small screens */
  .katex-display {
    overflow-x: auto;
    overflow-y: hidden;
    padding: 0.25rem 0;
  }
</style>
