---
import Base from './Base.astro';
import 'katex/dist/katex.min.css';

interface Props {
  title: string;
  date: Date;
  updated?: Date;
  description?: string;
  backHref: string;
  backLabel: string;
}

const { title, date, updated, description, backHref, backLabel } = Astro.props;

const fmt = (d: Date) =>
  // timeZone UTC: frontmatter dates parse as UTC midnight; local formatting shifts a day
  d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
const showUpdated = updated && fmt(updated) !== fmt(date);
---

<Base title={`${title} · Varun Gandhi`} description={description}>
  <article>
    <p class="back"><a href={backHref}>← {backLabel}</a></p>
    <h1>{title}</h1>
    <p class="entry-date">
      {fmt(date)}{showUpdated && <span class="entry-updated"> · Updated {fmt(updated)}</span>}
    </p>
    <slot />
  </article>
</Base>

<style>
  .back {
    margin-top: 2rem;
    font-size: 0.9rem;
  }

  article h1 {
    margin-top: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .entry-date {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-top: 0;
  }

  .entry-updated {
    font-style: italic;
  }
</style>
